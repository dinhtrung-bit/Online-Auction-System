<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auctions.client.controllers.AuctionDetailController"
      spacing="12"
      styleClass="root-pane">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Chi tiết phiên đấu giá" styleClass="title-label"/>

    <Label fx:id="idLabel" text="ID:"/>
    <Label fx:id="itemNameLabel" text="Tên sản phẩm:"/>
    <Label fx:id="currentPriceLabel" text="Giá hiện tại:"/>
    <Label fx:id="winnerLabel" text="Người dẫn đầu:"/>
    <Label fx:id="statusLabel" text="Trạng thái:"/>

    <TextField fx:id="bidAmountField" promptText="Nhập giá muốn đặt"/>
    <Button text="Đặt giá" onAction="#handleBid"/>
    <Button text="Quay lại" onAction="#handleBack"/>
</VBox>