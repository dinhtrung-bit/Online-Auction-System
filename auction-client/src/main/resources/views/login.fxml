<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auctions.client.controllers.LoginController"
      alignment="CENTER"
      spacing="15"
      styleClass="root-pane">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Online Auction System" styleClass="title-label"/>
    <TextField fx:id="usernameField" promptText="Username" maxWidth="260"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="260"/>
    <Button text="Login" onAction="#handleLogin" maxWidth="260"/>
    <Button text="Register" onAction="#handleRegister" maxWidth="260"/>
</VBox>