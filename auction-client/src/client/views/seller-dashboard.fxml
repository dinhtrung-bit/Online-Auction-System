<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="main-bg" stylesheets="@app.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.SellerDashboardController">

    <left>
        <VBox prefWidth="250.0" styleClass="sidebar">
            <padding><Insets top="20.0" bottom="20.0"/></padding>
            <Label text="AuctionVN Seller" textFill="WHITE">
                <font><Font name="System Bold" size="22.0" /></font>
                <VBox.margin><Insets bottom="30.0" left="20.0" right="20.0" /></VBox.margin>
            </Label>

            <Button maxWidth="Infinity" text="📦 Quản lý sản phẩm" styleClass="sidebar-btn, sidebar-btn-active" />
            <Button maxWidth="Infinity" text="➕ Đăng bán mới" styleClass="sidebar-btn" />
            <Button maxWidth="Infinity" text="📊 Báo cáo doanh thu" styleClass="sidebar-btn" />

            <Pane VBox.vgrow="ALWAYS" />

            <Button maxWidth="Infinity" text="🚪 Đăng xuất" styleClass="sidebar-btn" style="-fx-text-fill: #ef4444;" onAction="#handleLogout" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="Quản lý kho hàng">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Pane HBox.hgrow="ALWAYS" />
                <Button text="+ Thêm sản phẩm" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5;" />
            </HBox>

            <HBox spacing="20.0">
                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Đang đấu giá" styleClass="text-muted" />
                    <Label text="12 Phiên" textFill="#2563eb"><font><Font name="System Bold" size="20.0" /></font></Label>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Chờ duyệt" styleClass="text-muted" />
                    <Label text="5 Sản phẩm" textFill="#f59e0b"><font><Font name="System Bold" size="20.0" /></font></Label>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="5">
                    <Label text="Đã bán thành công" styleClass="text-muted" />
                    <Label text="48 Sản phẩm" textFill="#10b981"><font><Font name="System Bold" size="20.0" /></font></Label>
                </VBox>
            </HBox>

            <TableView fx:id="tableItems" VBox.vgrow="ALWAYS" styleClass="table-view-custom">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="80" />
                    <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="300" />
                    <TableColumn fx:id="colPrice" text="Giá hiện tại" prefWidth="150" />
                    <TableColumn fx:id="colWinner" text="Người dẫn đầu" prefWidth="150" />
                    <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="150" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>